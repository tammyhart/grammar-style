{
  "name": "grammar-style",
  "version": "0.3.9",
  "description": "A zero-runtime token resolution engine for design systems.",
  "keywords": [
    "design-tokens",
    "css-in-js",
    "linaria",
    "tailwind",
    "styled-components",
    "theme",
    "grammar-style",
    "stylex",
    "panda",
    "vanilla-extract"
  ],
  "homepage": "https://github.com/tammyhart/grammar-style#readme",
  "bugs": {
    "url": "https://github.com/tammyhart/grammar-style/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tammyhart/grammar-style.git"
  },
  "license": "MIT",
  "author": {
    "name": "Tammy Hart",
    "url": "https://github.com/tammyhart"
  },
  "sideEffects": false,
  "type": "commonjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./emotion": {
      "types": "./dist/adapters/emotion.d.ts",
      "import": "./dist/adapters/emotion.mjs",
      "require": "./dist/adapters/emotion.js"
    },
    "./linaria": {
      "types": "./dist/adapters/linaria.d.ts",
      "import": "./dist/adapters/linaria.mjs",
      "require": "./dist/adapters/linaria.js"
    },
    "./panda": {
      "types": "./dist/adapters/panda.d.ts",
      "import": "./dist/adapters/panda.mjs",
      "require": "./dist/adapters/panda.js"
    },
    "./styled-components": {
      "types": "./dist/adapters/styled-components.d.ts",
      "import": "./dist/adapters/styled-components.mjs",
      "require": "./dist/adapters/styled-components.js"
    },
    "./stylex": {
      "types": "./dist/adapters/stylex.d.ts",
      "import": "./dist/adapters/stylex.mjs",
      "require": "./dist/adapters/stylex.js"
    },
    "./tailwind": {
      "types": "./dist/adapters/tailwind.d.ts",
      "import": "./dist/adapters/tailwind.mjs",
      "require": "./dist/adapters/tailwind.js"
    },
    "./vanilla-extract": {
      "types": "./dist/adapters/vanilla-extract.d.ts",
      "import": "./dist/adapters/vanilla-extract.mjs",
      "require": "./dist/adapters/vanilla-extract.js"
    }
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "bin": {
    "grammar-init": "bin/init.mjs",
    "grammar-style": "bin/cli.mjs"
  },
  "directories": {
    "test": "test"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsup",
    "coverage": "vitest run --coverage --coverage.reporter=text",
    "prepublishOnly": "npm run build",
    "release": "changeset version && git add . && git commit -m \"chore: release\" && changeset tag",
    "sandbox": "npx jiti test/sandbox.ts",
    "test": "vitest run && npm run test:types",
    "test:types": "tsc --noEmit --strict src/types.test-d.ts"
  },
  "dependencies": {
    "jiti": "^2.6.1",
    "undici-types": "^7.18.2"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@emotion/react": "^11.14.0",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/styled-components": "^5.1.36",
    "@vitest/coverage-v8": "^4.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "styled-components": "^6.3.12",
    "tslib": "^2.8.1",
    "tsup": "^8.5.1",
    "typescript": "^5.5.0",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "@emotion/react": ">=11.0.0",
    "styled-components": ">=6.0.0"
  },
  "peerDependenciesMeta": {
    "@emotion/react": {
      "optional": true
    },
    "styled-components": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
