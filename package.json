{
  "name": "grammar-style",
  "version": "0.2.1",
  "description": "A zero-runtime token resolution engine for design systems.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./adapters/*": {
      "types": "./dist/adapters/*.d.ts",
      "import": "./dist/adapters/*.mjs",
      "require": "./dist/adapters/*.js"
    }
  },
  "files": [
    "dist",
    "bin"
  ],
  "bin": {
    "grammar-init": "bin/init.mjs"
  },
  "directories": {
    "test": "test"
  },
  "scripts": {
    "prepublishOnly": "npm run build",
    "build": "tsup",
    "test": "vitest run && npm run test:types",
    "test:types": "tsc --noEmit --strict src/types.test-d.ts",
    "sandbox": "npx jiti test/sandbox.ts",
    "coverage": "vitest run --coverage --coverage.reporter=text"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/grammar-style/grammar-style.git"
  },
  "keywords": [
    "design-tokens",
    "css-in-js",
    "linaria",
    "tailwind",
    "styled-components",
    "theme",
    "grammar-style",
    "stylex",
    "panda",
    "vanilla-extract"
  ],
  "author": "Grammar Style",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/grammar-style/grammar-style/issues"
  },
  "homepage": "https://github.com/grammar-style/grammar-style#readme",
  "dependencies": {
    "undici-types": "^7.18.2"
  },
  "peerDependencies": {
    "@emotion/react": ">=11.0.0",
    "@linaria/core": ">=3.0.0",
    "styled-components": ">=6.0.0"
  },
  "peerDependenciesMeta": {
    "@emotion/react": {
      "optional": true
    },
    "@linaria/core": {
      "optional": true
    },
    "styled-components": {
      "optional": true
    }
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@emotion/react": "^11.14.0",
    "@linaria/core": "^7.0.0",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/styled-components": "^5.1.36",
    "@vitest/coverage-v8": "^4.1.0",
    "jiti": "^2.6.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "styled-components": "^6.3.12",
    "tslib": "^2.8.1",
    "tsup": "^8.5.1",
    "typescript": "^5.5.0",
    "vitest": "^4.1.0"
  }
}
